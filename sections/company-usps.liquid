
{% assign s = section.settings %}

<div
  class="company-usps color-{{ s.color_scheme }} isolate gradient"
  style="
    padding-block-start: {{ s.padding_top }}px;
    padding-block-end: {{ s.padding_bottom }}px;
  "
>
  <div class="company-usps__inner page-width">

    <div class="company-usps__grid">

      <div class="company-usps__item">
        {% render 'icon-or-image',
          icon: s.usp1_icon,
          image_upload: s.usp1_image,
          width: s.icon_size,
          class_name: 'company-usps__icon'
        %}
        <div class="company-usps__text">
          {%- if s.usp1_heading != blank -%}
            <p class="company-usps__heading">{{ s.usp1_heading }}</p>
          {%- endif -%}
          {%- if s.usp1_subtext != blank -%}
            <p class="company-usps__subtext">{{ s.usp1_subtext }}</p>
          {%- endif -%}
        </div>
      </div>

      <div class="company-usps__item">
        {% render 'icon-or-image',
          icon: s.usp2_icon,
          image_upload: s.usp2_image,
          width: s.icon_size,
          class_name: 'company-usps__icon'
        %}
        <div class="company-usps__text">
          {%- if s.usp2_heading != blank -%}
            <p class="company-usps__heading">{{ s.usp2_heading }}</p>
          {%- endif -%}
          {%- if s.usp2_subtext != blank -%}
            <p class="company-usps__subtext">{{ s.usp2_subtext }}</p>
          {%- endif -%}
        </div>
      </div>

      <div class="company-usps__item">
        {% render 'icon-or-image',
          icon: s.usp3_icon,
          image_upload: s.usp3_image,
          width: s.icon_size,
          class_name: 'company-usps__icon'
        %}
        <div class="company-usps__text">
          {%- if s.usp3_heading != blank -%}
            <p class="company-usps__heading">{{ s.usp3_heading }}</p>
          {%- endif -%}
          {%- if s.usp3_subtext != blank -%}
            <p class="company-usps__subtext">{{ s.usp3_subtext }}</p>
          {%- endif -%}
        </div>
      </div>

      <div class="company-usps__item">
        {% render 'icon-or-image',
          icon: s.usp4_icon,
          image_upload: s.usp4_image,
          width: s.icon_size,
          class_name: 'company-usps__icon'
        %}
        <div class="company-usps__text">
          {%- if s.usp4_heading != blank -%}
            <p class="company-usps__heading">{{ s.usp4_heading }}</p>
          {%- endif -%}
          {%- if s.usp4_subtext != blank -%}
            <p class="company-usps__subtext">{{ s.usp4_subtext }}</p>
          {%- endif -%}
        </div>
      </div>

    </div>
  </div>
</div>

{% stylesheet %}
  .company-usps__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 3rem;
  }

  @media screen and (max-width: 749px) {
    .company-usps__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 2rem;
    }
  }

  .company-usps__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1rem;
  }

  .company-usps__icon {
    color: currentColor;
  }

  .company-usps__text {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .company-usps__heading {
    margin: 0;
    font-size: 1.4rem;
    font-weight: 600;
    line-height: 1.4;
  }

  .company-usps__subtext {
    margin: 0;
    font-size: 1.4rem;
    color: rgba(var(--color-foreground), 0.75);
    line-height: 1.4;
  }
{% endstylesheet %}

