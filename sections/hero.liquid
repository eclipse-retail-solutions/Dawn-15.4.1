{% liquid
  assign max_slots = 6
  assign slide_count = 0

  for i in (1..max_slots)
    assign image_key = 'image_' | append: i
    assign video_key = 'video_' | append: i
    assign type_key  = 'media_type_' | append: i
    if section.settings[image_key] != blank and section.settings[type_key] == 'image'
      assign slide_count = slide_count | plus: 1
    elsif section.settings[video_key] != blank and section.settings[type_key] == 'video'
      assign slide_count = slide_count | plus: 1
    endif
  endfor

  assign widths = '832, 1200, 1600, 1920, 2560, 3840'
  assign mobile_widths = '416, 600, 800, 1200, 1600'
  assign mobile_widths_array = mobile_widths | split: ', '

  assign fetch_priority = 'auto'
  if section.index == 1
    assign fetch_priority = 'high'
  endif

  assign autoplay_ms = section.settings.autoplay_speed | times: 1000
%}

<hero-slideshow
  id="Hero-{{ section.id }}"
  class="hero color-{{ section.settings.color_scheme }}"
  {% if section.settings.autoplay and slide_count > 1 %}data-autoplay="{{ autoplay_ms }}"{% endif %}
  style="
    --blur-opacity: {{ section.settings.reflection_opacity | divided_by: 100.0 }};
    {% if section.settings.section_height == 'custom' %}
      --hero-min-height: {{ section.settings.section_height_custom }}svh;
    {% elsif section.settings.section_height == 'full-screen' %}
      --hero-min-height: 100svh;
    {% else %}
      --hero-min-height: var(--section-height-{{ section.settings.section_height }}, 25rem);
    {% endif %}
  "
  {% if request.visual_preview_mode %}data-shopify-visual-preview{% endif %}
>
  {%- comment -%} ── Slides track ──────────────────────────────────────────── {%- endcomment -%}
  <div class="hero__slides-track" data-hero-track>

    {%- assign slide_index = 0 -%}
    {%- for i in (1..max_slots) -%}
      {%- assign image_key  = 'image_' | append: i -%}
      {%- assign video_key  = 'video_' | append: i -%}
      {%- assign type_key   = 'media_type_' | append: i -%}
      {%- assign image_key_m = 'image_' | append: i | append: '_mobile' -%}
      {%- assign video_key_m = 'video_' | append: i | append: '_mobile' -%}
      {%- assign type_key_m  = 'media_type_' | append: i | append: '_mobile' -%}

      {%- assign desktop_type = 'none' -%}
      {%- assign mobile_type  = 'none' -%}

      {%- if section.settings[image_key] != blank and section.settings[type_key] == 'image' -%}
        {%- assign desktop_type = 'image' -%}
      {%- elsif section.settings[video_key] != blank and section.settings[type_key] == 'video' -%}
        {%- assign desktop_type = 'video' -%}
      {%- endif -%}

      {%- if section.settings.custom_mobile_media -%}
        {%- if section.settings[image_key_m] != blank and section.settings[type_key_m] == 'image' -%}
          {%- assign mobile_type = 'image' -%}
        {%- elsif section.settings[video_key_m] != blank and section.settings[type_key_m] == 'video' -%}
          {%- assign mobile_type = 'video' -%}
        {%- endif -%}
      {%- endif -%}

      {%- if desktop_type != 'none' -%}
        {%- assign slide_index = slide_index | plus: 1 -%}
        <div
          class="hero__slide{% if slide_index == 1 %} hero__slide--active{% endif %}"
          data-hero-slide
          role="group"
          aria-roledescription="slide"
          aria-label="Slide {{ slide_index }} of {{ slide_count }}"
          {% if slide_index > 1 %}aria-hidden="true"{% endif %}
        >
          {%- comment -%} Desktop + mobile art-directed image {%- endcomment -%}
          {%- if desktop_type == 'image' and mobile_type == 'image' -%}
            <picture>
              <source
                media="(max-width: 749px)"
                srcset="
                  {%- for w in mobile_widths_array -%}
                    {{ section.settings[image_key_m] | image_url: width: w }} {{ w }}w{% unless forloop.last %},{% endunless %}
                  {%- endfor -%}
                "
                sizes="100vw"
                width="{{ section.settings[image_key_m].width }}"
                height="{{ section.settings[image_key_m].height }}"
              >
              {{
                section.settings[image_key]
                | image_url: width: 3840
                | image_tag:
                  width: section.settings[image_key].width,
                  widths: widths,
                  height: section.settings[image_key].height,
                  alt: section.settings[image_key].alt,
                  class: 'hero__media',
                  sizes: '100vw',
                  fetchpriority: fetch_priority
              }}
            </picture>

          {%- comment -%} Desktop image, no custom mobile {%- endcomment -%}
          {%- elsif desktop_type == 'image' -%}
            {{
              section.settings[image_key]
              | image_url: width: 3840
              | image_tag:
                width: section.settings[image_key].width,
                widths: widths,
                height: section.settings[image_key].height,
                alt: section.settings[image_key].alt,
                class: 'hero__media',
                sizes: '100vw',
                fetchpriority: fetch_priority
            }}

          {%- comment -%} Desktop video {%- endcomment -%}
          {%- elsif desktop_type == 'video' -%}
            {{
              section.settings[video_key]
              | video_tag:
                poster: nil,
                autoplay: true,
                loop: true,
                controls: false,
                muted: true,
                class: 'hero__media'
            }}
          {%- endif -%}

          {%- if section.settings.toggle_overlay -%}
            {%- render 'overlay', settings: section.settings -%}
          {%- endif -%}
        </div>
        {%- assign fetch_priority = 'auto' -%}
      {%- endif -%}
    {%- endfor -%}

    {%- if slide_count == 0 -%}
      <div class="hero__slide hero__slide--active" data-hero-slide>
        {{ 'hero-apparel-1' | placeholder_svg_tag: 'hero__media' }}
      </div>
    {%- endif -%}
  </div>

  {%- comment -%} ── Content overlay ───────────────────────────────────────── {%- endcomment -%}
  <div
    class="hero__content-wrapper layout-panel-flex layout-panel-flex--{{ section.settings.content_direction }} {% if section.settings.vertical_on_mobile %}mobile-column{% endif %} {{ section.settings.section_width }} {% if request.design_mode %}hero__content-wrapper--design-mode{% endif %}"
    style="{% render 'layout-panel-style', settings: section.settings %}"
  >
    {%- if section.settings.link != blank -%}
      <a
        href="{{ section.settings.link }}"
        class="hero__link"
        {% if section.settings.open_in_new_tab %}target="_blank" rel="noopener"{% endif %}
      ></a>
    {%- endif -%}

    {%- for block in section.blocks -%}
      {%- case block.type -%}
        {%- when 'heading' -%}
          <h2 class="hero__heading inline-richtext {{ block.settings.heading_size }}" {{ block.shopify_attributes }}>
            {{ block.settings.heading }}
          </h2>
        {%- when 'text' -%}
          <div class="hero__text rte {{ block.settings.text_style }}" {{ block.shopify_attributes }}>
            <p>{{ block.settings.text }}</p>
          </div>
        {%- when 'buttons' -%}
          <div
            class="hero__buttons{% if block.settings.button_label_1 != blank and block.settings.button_label_2 != blank %} hero__buttons--multiple{% endif %}"
            {{ block.shopify_attributes }}
          >
            {%- if block.settings.button_label_1 != blank -%}
              <a
                {% if block.settings.button_link_1 == blank %}role="link" aria-disabled="true"{% else %}href="{{ block.settings.button_link_1 }}"{% endif %}
                class="button{% if block.settings.button_style_secondary_1 %} button--secondary{% else %} button--primary{% endif %}"
              >
                {{- block.settings.button_label_1 | escape -}}
              </a>
            {%- endif -%}
            {%- if block.settings.button_label_2 != blank -%}
              <a
                {% if block.settings.button_link_2 == blank %}role="link" aria-disabled="true"{% else %}href="{{ block.settings.button_link_2 }}"{% endif %}
                class="button{% if block.settings.button_style_secondary_2 %} button--secondary{% else %} button--primary{% endif %}"
              >
                {{- block.settings.button_label_2 | escape -}}
              </a>
            {%- endif -%}
          </div>
      {%- endcase -%}
    {%- endfor -%}
  </div>

  {%- comment -%} ── Slideshow controls (only when >1 slide) ─────────────────── {%- endcomment -%}
  {%- if slide_count > 1 -%}
    {%- if section.settings.show_arrows -%}
      <button class="hero__nav-btn hero__nav-btn--prev" data-hero-prev aria-label="Previous slide">
        <span class="svg-wrapper">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
            <path d="M12.5 15L7.5 10L12.5 5"/>
          </svg>
        </span>
      </button>
      <button class="hero__nav-btn hero__nav-btn--next" data-hero-next aria-label="Next slide">
        <span class="svg-wrapper">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
            <path d="M7.5 15L12.5 10L7.5 5"/>
          </svg>
        </span>
      </button>
    {%- endif -%}

    {%- if section.settings.show_dots -%}
      <div class="hero__dots" role="tablist" data-hero-dots>
        {%- for i in (1..slide_count) -%}
          <button
            class="hero__dot{% if forloop.first %} hero__dot--active{% endif %}"
            data-hero-dot="{{ forloop.index0 }}"
            role="tab"
            aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
            aria-label="Slide {{ i }}"
          ></button>
        {%- endfor -%}
      </div>
    {%- endif -%}
  {%- endif -%}
</hero-slideshow>

<script>
  (() => {
    if (customElements.get('hero-slideshow')) return;

    class HeroSlideshow extends HTMLElement {
      connectedCallback() {
        this._current = 0;
        this._slides = Array.from(this.querySelectorAll('[data-hero-slide]'));
        this._dots   = Array.from(this.querySelectorAll('[data-hero-dot]'));
        this._track  = this.querySelector('[data-hero-track]');

        this.querySelector('[data-hero-prev]')
          ?.addEventListener('click', () => this._step(-1));
        this.querySelector('[data-hero-next]')
          ?.addEventListener('click', () => this._step(1));

        this._dots.forEach(dot => {
          dot.addEventListener('click', () => this._goTo(parseInt(dot.dataset.heroDot)));
        });

        const ms = parseInt(this.dataset.autoplay);
        if (ms > 0 && this._slides.length > 1) {
          this._startAutoplay(ms);
          this.addEventListener('mouseenter', () => this._stopAutoplay());
          this.addEventListener('mouseleave', () => this._startAutoplay(ms));
          this.addEventListener('focusin',    () => this._stopAutoplay());
          this.addEventListener('focusout',   () => this._startAutoplay(ms));
        }

        // Keyboard navigation
        this.addEventListener('keydown', (e) => {
          if (e.key === 'ArrowLeft')  this._step(-1);
          if (e.key === 'ArrowRight') this._step(1);
        });
      }

      disconnectedCallback() {
        this._stopAutoplay();
      }

      _goTo(index) {
        const total = this._slides.length;
        const next  = ((index % total) + total) % total;
        const prev  = this._current;

        if (next === prev) return;

        this._slides[prev].classList.remove('hero__slide--active');
        this._slides[prev].setAttribute('aria-hidden', 'true');

        this._slides[next].classList.add('hero__slide--active');
        this._slides[next].removeAttribute('aria-hidden');

        this._dots.forEach((dot, i) => {
          dot.classList.toggle('hero__dot--active', i === next);
          dot.setAttribute('aria-selected', i === next ? 'true' : 'false');
        });

        this._current = next;
      }

      _step(dir) {
        this._goTo(this._current + dir);
      }

      _startAutoplay(ms) {
        this._stopAutoplay();
        this._timer = setInterval(() => this._step(1), ms);
      }

      _stopAutoplay() {
        clearInterval(this._timer);
      }
    }

    customElements.define('hero-slideshow', HeroSlideshow);
  })();
</script>

{% stylesheet %}
  :root {
    --section-height-small: 15rem;
    --section-height-medium: 25rem;
    --section-height-large: 35rem;
    --layer-base: 0;
    --layer-flat: 1;
    --layer-raised: 2;
  }

  @media screen and (min-width: 750px) {
    :root {
      --section-height-small: 40svh;
      --section-height-medium: 55svh;
      --section-height-large: 70svh;
    }
  }

  @media screen and (min-width: 990px) {
    :root {
      --section-height-small: 50svh;
      --section-height-medium: 65svh;
      --section-height-large: 80svh;
    }
  }

  .hero-wrapper {
    --hero-height-offset: 0px;
  }

  body:has(> #header-group > .header-section > #header-component) .hero-wrapper:first-child {
    --hero-height-offset: var(--header-group-height, 0);
  }

  hero-slideshow {
    display: block;
    position: relative;
    overflow: hidden;
    min-height: calc(var(--hero-min-height, 25rem) - var(--hero-height-offset, 0px));
  }

  hero-slideshow[data-shopify-visual-preview] {
    --hero-min-height: 600px;
    min-height: 600px;
  }

  /* ── Track & slides ──────────────────────────────── */
  .hero__slides-track {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .hero__slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 0.6s ease;
    pointer-events: none;
  }

  .hero__slide--active {
    opacity: 1;
    pointer-events: auto;
  }

  .hero__media {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center center;
    display: block;
  }

  .hero__slide picture {
    display: block;
    width: 100%;
    height: 100%;
  }

  /* ── Content wrapper ─────────────────────────────── */
  .hero__content-wrapper {
    position: relative;
    z-index: var(--layer-flat);
    min-height: inherit;
    padding-block: var(--padding-block-start, 0) var(--padding-block-end, 0);
  }

  .hero__content-wrapper.page-width {
    margin-inline: auto;
  }

  .hero__link {
    position: absolute;
    inset: 0;
    z-index: var(--layer-raised);
  }

  .hero__heading,
  .hero__text {
    color: inherit;
  }

  .hero__buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .layout-panel-flex {
    display: flex;
    flex-direction: var(--flex-direction, column);
    flex-wrap: var(--flex-wrap-mobile, wrap);
    gap: var(--gap, 1rem);
    align-items: var(--vertical-alignment-mobile, center);
    justify-content: var(--horizontal-alignment, flex-start);

    @media screen and (min-width: 750px) {
      flex-wrap: var(--flex-wrap, nowrap);
      align-items: var(--vertical-alignment, center);
    }
  }

  .layout-panel-flex.mobile-column {
    @media screen and (max-width: 749px) {
      flex-direction: column;
    }
  }

  .hero__content-wrapper--design-mode * {
    pointer-events: auto;
  }

  /* ── Prev / Next arrows ─────────────────────────── */
  .hero__nav-btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: var(--layer-raised);
    display: flex;
    align-items: center;
    justify-content: center;
    width: 3.6rem;
    height: 3.6rem;
    padding: 0;
    background: rgb(var(--color-background-rgb, 255 255 255) / 0.7);
    border: 0.1rem solid rgb(var(--color-border-rgb, 0 0 0) / 0.2);
    border-radius: 50%;
    cursor: pointer;
    color: rgb(var(--color-foreground-rgb, 0 0 0));
    transition: background 0.2s, border-color 0.2s;
  }

  .hero__nav-btn:hover {
    background: rgb(var(--color-background-rgb, 255 255 255) / 0.95);
  }

  .hero__nav-btn--prev { left: 1.5rem; }
  .hero__nav-btn--next { right: 1.5rem; }

  .hero__nav-btn .svg-wrapper {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* ── Dot indicators ─────────────────────────────── */
  .hero__dots {
    position: absolute;
    bottom: 1.5rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: var(--layer-raised);
    display: flex;
    gap: 0.6rem;
  }

  .hero__dot {
    width: 0.8rem;
    height: 0.8rem;
    padding: 0;
    border-radius: 50%;
    border: 0.15rem solid currentColor;
    background: transparent;
    cursor: pointer;
    opacity: 0.5;
    transition: opacity 0.2s, background 0.2s;
    color: rgb(var(--color-background-rgb, 255 255 255));
  }

  .hero__dot--active {
    background: currentColor;
    opacity: 1;
  }

  /* ── Spacing style passthrough ───────────────────── */
  .spacing-style {
    padding-block-start: var(--padding-block-start, 0);
    padding-block-end: var(--padding-block-end, 0);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Hero",
  "tag": "section",
  "class": "hero-wrapper section-wrapper",
  "disabled_on": {
    "groups": ["header"]
  },
  "blocks": [
    {
      "type": "heading",
      "name": "Heading",
      "limit": 1,
