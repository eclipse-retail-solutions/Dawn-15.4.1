{% liquid
  assign max_slots = 6
  assign media_count = 0
  assign has_only_video = true
  assign fallback_to_desktop = false
  assign media_count_mobile = 0
  assign has_only_video_mobile = true

  for i in (1..max_slots)
    assign image_key = 'image_' | append: i
    assign video_key = 'video_' | append: i
    assign type_key = 'media_type_' | append: i
    if section.settings[image_key] != blank and section.settings[type_key] == 'image'
      assign media_count = media_count | plus: 1
      assign has_only_video = false
    elsif section.settings[video_key] != blank and section.settings[type_key] == 'video'
      assign media_count = media_count | plus: 1
    endif
  endfor

  if media_count == 0
    assign has_only_video = false
  endif

  if section.settings.custom_mobile_media
    for i in (1..max_slots)
      assign image_key_m = 'image_' | append: i | append: '_mobile'
      assign video_key_m = 'video_' | append: i | append: '_mobile'
      assign type_key_m = 'media_type_' | append: i | append: '_mobile'
      if section.settings[image_key_m] != blank and section.settings[type_key_m] == 'image'
        assign media_count_mobile = media_count_mobile | plus: 1
        assign has_only_video_mobile = false
      elsif section.settings[video_key_m] != blank and section.settings[type_key_m] == 'video'
        assign media_count_mobile = media_count_mobile | plus: 1
      endif
    endfor
  endif

  if media_count_mobile == 0
    assign has_only_video_mobile = false
  endif

  assign media_wrapper_desktop_class = 'hero__media-wrapper hero__media-wrapper--desktop'
  assign media_wrapper_mobile_class = 'hero__media-wrapper hero__media-wrapper--mobile'

  if section.settings.custom_mobile_media == false or section.settings.custom_mobile_media == true and media_count_mobile == 0
    assign media_wrapper_desktop_class = media_wrapper_desktop_class | append: ' hero__media-wrapper--mobile'
  endif

  assign show_mobile_blurred_reflection = false
  if section.settings.blurred_reflection
    if section.settings.custom_mobile_media == true and media_count_mobile > 0 and has_only_video_mobile == false
      assign show_mobile_blurred_reflection = true
    elsif section.settings.custom_mobile_media == true and media_count_mobile == 0 and media_count > 0 and has_only_video == false
      assign show_mobile_blurred_reflection = true
    elsif section.settings.custom_mobile_media == false and media_count > 0 and has_only_video == false
      assign show_mobile_blurred_reflection = true
    endif
  endif

  if media_count > 0
    assign media_width_desktop_num = 100 | divided_by: media_count
  else
    assign media_width_desktop_num = 100
  endif
  assign media_width_desktop = media_width_desktop_num | append: 'vw'

  if section.settings.custom_mobile_media == false or media_count_mobile == 0 or media_count == 0
    assign media_count_mobile = media_count
    assign fallback_to_desktop = true
  endif

  if fallback_to_desktop
    assign media_width_mobile = media_width_desktop
  elsif section.settings.stack_media_on_mobile
    assign media_width_mobile = '100vw'
  elsif media_count_mobile > 0
    assign media_width_mobile_num = 100 | divided_by: media_count_mobile
    assign media_width_mobile = media_width_mobile_num | append: 'vw'
  else
    assign media_width_mobile = '100vw'
  endif

  assign sizes = '(min-width: 750px) ' | append: media_width_desktop | append: ', ' | append: media_width_mobile
  assign widths = '832, 1200, 1600, 1920, 2560, 3840'
  assign sizes_mobile = media_width_mobile
  assign mobile_widths = '416, 600, 800, 1200, 1600'
  assign mobile_widths_array = mobile_widths | split: ', '

  assign fetch_priority = 'auto'
  if section.index == 1
    assign fetch_priority = 'high'
  endif
%}

{% capture media %}
  {% for i in (1..max_slots) %}
    {%- assign image_key = 'image_' | append: i -%}
    {%- assign video_key = 'video_' | append: i -%}
    {%- assign type_key = 'media_type_' | append: i -%}
    {%- assign image_key_m = 'image_' | append: i | append: '_mobile' -%}
    {%- assign video_key_m = 'video_' | append: i | append: '_mobile' -%}
    {%- assign type_key_m = 'media_type_' | append: i | append: '_mobile' -%}
    {%- assign media_i = 'none' -%}
    {%- assign media_i_mobile = 'none' -%}

    {%- if section.settings[image_key] != blank and section.settings[type_key] == 'image' -%}
      {%- assign media_i = 'image' -%}
    {%- elsif section.settings[video_key] != blank and section.settings[type_key] == 'video' -%}
      {%- assign media_i = 'video' -%}
    {%- endif -%}

    {%- if section.settings.custom_mobile_media and fallback_to_desktop == false -%}
      {%- if section.settings[image_key_m] != blank and section.settings[type_key_m] == 'image' -%}
        {%- assign media_i_mobile = 'image' -%}
      {%- elsif section.settings[video_key_m] != blank and section.settings[type_key_m] == 'video' -%}
        {%- assign media_i_mobile = 'video' -%}
      {%- endif -%}
    {%- endif -%}

    {%- if media_i == 'image' and media_i_mobile == 'image' -%}
      <picture class="hero__media">
        <source
          media="(max-width: 749px)"
          srcset="
            {%- for mobile_width in mobile_widths_array -%}
              {{ section.settings[image_key_m] | image_url: width: mobile_width }} {{ mobile_width }}w{% unless forloop.last %},{% endunless %}
            {%- endfor -%}
          "
          sizes="{{ sizes_mobile }}"
          width="{{ section.settings[image_key_m].width }}"
          height="{{ section.settings[image_key_m].height }}"
        >
        {{
          section.settings[image_key]
          | image_url: width: 3840
          | image_tag:
            width: section.settings[image_key].width,
            widths: widths,
            height: section.settings[image_key].height,
            alt: section.settings[image_key].alt,
            class: 'hero__media',
            sizes: sizes,
            fetchpriority: fetch_priority
        }}
      </picture>
    {%- elsif media_i == 'image' -%}
      <div class="{{ media_wrapper_desktop_class }}">
        {{
          section.settings[image_key]
          | image_url: width: 3840
          | image_tag:
            width: section.settings[image_key].width,
            widths: widths,
            height: section.settings[image_key].height,
            alt: section.settings[image_key].alt,
            class: 'hero__media',
            sizes: sizes,
            fetchpriority: fetch_priority
        }}
      </div>
    {%- endif -%}

    {%- if media_i == 'video' -%}
      <div class="{{ media_wrapper_desktop_class }}">
        {{
          section.settings[video_key]
          | video_tag:
            poster: nil,
            autoplay: true,
            loop: true,
            controls: false,
            muted: true,
            class: 'hero__media'
        }}
      </div>
    {%- endif -%}

    {%- if section.settings.custom_mobile_media and fallback_to_desktop == false -%}
      {%- if media_i_mobile == 'image' and media_i != 'image' -%}
        <div class="{{ media_wrapper_mobile_class }}">
          {{
            section.settings[image_key_m]
            | image_url: width: 1600
            | image_tag:
              width: section.settings[image_key_m].width,
              widths: mobile_widths,
              height: section.settings[image_key_m].height,
              alt: section.settings[image_key_m].alt,
              class: 'hero__media',
              sizes: sizes_mobile,
              fetchpriority: fetch_priority
          }}
        </div>
      {%- endif -%}

      {%- if media_i_mobile == 'video' -%}
        <div class="{{ media_wrapper_mobile_class }}">
          {{
            section.settings[video_key_m]
            | video_tag:
              poster: nil,
              autoplay: true,
              loop: true,
              controls: false,
              muted: true,
              class: 'hero__media'
          }}
        </div>
      {%- endif -%}
    {%- endif -%}
  {% endfor %}

  {% if media_count == 0 %}
    {{ 'hero-apparel-1' | placeholder_svg_tag: 'hero__media' }}
  {% endif %}
{% endcapture %}

{% capture media_blurred %}
  {%- for i in (1..max_slots) -%}
    {%- assign image_key = 'image_' | append: i -%}
    {%- assign type_key = 'media_type_' | append: i -%}
    {%- if section.settings[image_key] != blank and section.settings[type_key] == 'image' -%}
      {{
        section.settings[image_key]
        | image_url: width: 3840
        | image_tag:
          width: section.settings[image_key].width,
          widths: widths,
          height: section.settings[image_key].height,
          alt: '',
          class: 'hero__media',
          sizes: sizes
      }}
    {%- endif -%}
  {%- endfor -%}
  {%- if media_count == 0 -%}
    {{ 'hero-apparel-1' | placeholder_svg_tag: 'hero__media' }}
  {%- endif -%}
{% endcapture %}

{% capture mobile_media_blurred %}
  {%- if section.settings.stack_media_on_mobile == false -%}
    {%- if section.settings.custom_mobile_media == true and fallback_to_desktop == false -%}
      {%- for i in (1..max_slots) -%}
        {%- assign image_key_m = 'image_' | append: i | append: '_mobile' -%}
        {%- assign type_key_m = 'media_type_' | append: i | append: '_mobile' -%}
        {%- if section.settings[image_key_m] != blank and section.settings[type_key_m] == 'image' -%}
          {{
            section.settings[image_key_m]
            | image_url: width: 1600
            | image_tag:
              width: section.settings[image_key_m].width,
              widths: mobile_widths,
              height: section.settings[image_key_m].height,
              alt: '',
              class: 'hero__media',
              sizes: sizes_mobile
          }}
        {%- endif -%}
      {%- endfor -%}
    {%- elsif fallback_to_desktop -%}
      {{ media_blurred }}
    {%- endif -%}
  {%- elsif section.settings.stack_media_on_mobile == true -%}
    {%- if section.settings.custom_mobile_media == true and fallback_to_desktop == false -%}
      {%- assign found_mobile_blurred = false -%}
      {%- for i in (max_slots..1) -%}
        {%- unless found_mobile_blurred -%}
          {%- assign image_key_m = 'image_' | append: i | append: '_mobile' -%}
          {%- assign type_key_m = 'media_type_' | append: i | append: '_mobile' -%}
          {%- if section.settings[image_key_m] != blank and section.settings[type_key_m] == 'image' -%}
            {{
              section.settings[image_key_m]
              | image_url: width: 1600
              | image_tag:
                width: section.settings[image_key_m].width,
                widths: mobile_widths,
                height: section.settings[image_key_m].height,
                alt: '',
                class: 'hero__media',
                sizes: sizes_mobile
            }}
            {%- assign found_mobile_blurred = true -%}
          {%- endif -%}
        {%- endunless -%}
      {%- endfor -%}
    {%- elsif fallback_to_desktop -%}
      {%- if media_count > 0 -%}
        {%- assign found_desktop_blurred = false -%}
        {%- for i in (max_slots..1) -%}
          {%- unless found_desktop_blurred -%}
            {%- assign image_key = 'image_' | append: i -%}
            {%- assign type_key = 'media_type_' | append: i -%}
            {%- if section.settings[image_key] != blank and section.settings[type_key] == 'image' -%}
              {{
                section.settings[image_key]
                | image_url: width: 1600
                | image_tag:
                  width: section.settings[image_key].width,
                  widths: widths,
                  height: section.settings[image_key].height,
                  alt: '',
                  class: 'hero__media',
                  sizes: sizes
              }}
              {%- assign found_desktop_blurred = true -%}
            {%- endif -%}
          {%- endunless -%}
        {%- endfor -%}
      {%- endif -%}
    {%- endif -%}
  {%- endif -%}
{% endcapture %}

<div
  id="Hero-{{ section.id }}"
  class="hero color-{{ section.settings.color_scheme }}{% if section.blocks.size == 0 and section.settings.section_height == 'auto' %} hero--no-blocks-auto-height{% endif %}{% if section.settings.stack_media_on_mobile %} hero--stack-mobile{% endif %}"
  style="
    --hero-border-style: {{ section.settings.border }};
    --hero-border-width: {{ section.settings.border_width }}px;
    --hero-border-opacity: {{ section.settings.border_opacity }}%;
    --blur-opacity: {{ section.settings.reflection_opacity | divided_by: 100.0 }};
    {% if section.settings.section_height == 'custom' %}
      --hero-min-height: {{ section.settings.section_height_custom }}svh;
    {% elsif section.settings.section_height == 'full-screen' %}
      --hero-min-height: 100svh;
    {% else %}
      --hero-min-height: var(--section-height-{{ section.settings.section_height }}, 25rem);
    {% endif %}
  "
  {% if request.visual_preview_mode %}
    data-shopify-visual-preview
  {% endif %}
  {% if section.settings.blurred_reflection and has_only_video == false or has_only_video_mobile == false %}
    data-blur-shadow="true"
  {% endif %}
>
  {% if section.settings.blurred_reflection %}
    {% unless has_only_video %}
      <div
        class="hero__blurred-image hero__blurred-image--desktop"
      >
        {{ media_blurred }}
      </div>
    {% endunless %}
    {% if show_mobile_blurred_reflection %}
      <div
        class="hero__blurred-image hero__blurred-image--mobile"
      >
        {{ mobile_media_blurred }}
      </div>
    {% endif %}
  {% endif %}

  <div
    class="hero__container spacing-style section section--full-width"
    style="{% render 'spacing-style', settings: section.settings %}"
  >
    {%- if section.settings.link != blank -%}
      <a
        href="{{ section.settings.link }}"
        class="hero__link"
        {% if section.settings.open_in_new_tab %}
          target="_blank" rel="noopener"
        {% endif %}
      ></a>
    {%- endif -%}

    <div
      class="hero__media-grid"
      style="--hero-media-count: {{ media_count }};--hero-media-count-mobile: {{ media_count_mobile }};{%- if section.settings.image_1 != blank -%} --hero-media-aspect-ratio: {{ section.settings.image_1.aspect_ratio }};{%- endif -%}"
    >
      {% if section.settings.toggle_overlay %}
        {% render 'overlay', settings: section.settings %}
      {% endif %}
      {{ media }}
    </div>

    <div
      class="
        hero__content-wrapper
        layout-panel-flex
        layout-panel-flex--{{ section.settings.content_direction }}
        {% if section.settings.vertical_on_mobile %}mobile-column{% endif %}
        section-content-wrapper
        {{ section.settings.section_width }}
        {% if request.design_mode %}hero__content-wrapper--design-mode{% endif %}
      "
      style="{% render 'layout-panel-style', settings: section.settings %}"
    >
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'heading' -%}
            <h2
              class="hero__heading inline-richtext {{ block.settings.heading_size }}"
              {{ block.shopify_attributes }}
            >
              {{ block.settings.heading }}
            </h2>
          {%- when 'text' -%}
            <div class="hero__text rte {{ block.settings.text_style }}" {{ block.shopify_attributes }}>
              <p>{{ block.settings.text }}</p>
            </div>
          {%- when 'buttons' -%}
            <div
              class="hero__buttons{% if block.settings.button_label_1 != blank and block.settings.button_label_2 != blank %} hero__buttons--multiple{% endif %}"
              {{ block.shopify_attributes }}
            >
              {%- if block.settings.button_label_1 != blank -%}
                <a
                  {% if block.settings.button_link_1 == blank %}
                    role="link" aria-disabled="true"
                  {% else %}
                    href="{{ block.settings.button_link_1 }}"
                  {% endif %}
                  class="button{% if block.settings.button_style_secondary_1 %} button--secondary{% else %} button--primary{% endif %}"
                >
                  {{- block.settings.button_label_1 | escape -}}
                </a>
              {%- endif -%}
              {%- if block.settings.button_label_2 != blank -%}
                <a
                  {% if block.settings.button_link_2 == blank %}
                    role="link" aria-disabled="true"
                  {% else %}
                    href="{{ block.settings.button_link_2 }}"
                  {% endif %}
                  class="button{% if block.settings.button_style_secondary_2 %} button--secondary{% else %} button--primary{% endif %}"
                >
                  {{- block.settings.button_label_2 | escape -}}
                </a>
              {%- endif -%}
            </div>
        {%- endcase -%}
      {%- endfor -%}
    </div>
  </div>
</div>

{% stylesheet %}
  :root {
    --section-height-small: 15rem;
    --section-height-medium: 25rem;
    --section-height-large: 35rem;
    --layer-base: 0;
    --layer-flat: 1;
    --layer-raised: 2;
  }

  @media screen and (min-width: 750px) {
    :root {
      --section-height-small: 40svh;
      --section-height-medium: 55svh;
      --section-height-large: 70svh;
    }
  }

  @media screen and (min-width: 990px) {
    :root {
      --section-height-small: 50svh;
      --section-height-medium: 65svh;
      --section-height-large: 80svh;
    }
  }

  .hero-wrapper {
    --hero-height-offset: 0px;
  }

  body:has(> #header-group > .header-section > #header-component) .hero-wrapper:first-child {
    --hero-height-offset: var(--header-group-height, 0);
  }

  .hero {
    position: relative;
    min-height: calc(var(--hero-min-height) - var(--hero-height-offset));
  }

  .hero[data-shopify-visual-preview] {
    --hero-min-height: 600px;
    min-height: 600px;
  }

  .hero__container {
    position: relative;
    overflow: hidden;
    border: var(--hero-border-width, 0) var(--hero-border-style, none) rgb(var(--color-border-rgb, 0 0 0) / var(--hero-border-opacity, 0%));
    min-height: inherit;
    align-items: var(--vertical-alignment-mobile, center);
    justify-content: var(--horizontal-alignment, flex-start);
    z-index: var(--layer-base);

    @media screen and (min-width: 750px) {
      align-items: var(--vertical-alignment, center);
    }
  }

  .hero__content-wrapper.page-width {
    grid-column: 2 / 3;
  }

  .hero__content-wrapper {
    position: relative;
    inset: 0;
    z-index: var(--layer-flat);
  }

  .hero__media-grid {
    position: absolute;
    inset: 0;
    display: grid;
    grid-column: 1 / -1;
    grid-template-columns: repeat(var(--hero-media-count, 1), 1fr);
  }

  .hero--auto .hero__media {
    aspect-ratio: var(--hero-media-aspect-ratio);
  }

  .hero--no-blocks-auto-height {
    .hero__media {
      width: 100%;
      aspect-ratio: auto;
    }

    .hero__media-grid {
      position: relative;
    }
  }

  .hero__media-wrapper {
    overflow: hidden;
    position: relative;
  }

  .hero__media {
    height: 100%;
    width: 100%;
    object-fit: cover;
    object-position: center center;
    overflow: hidden;
    position: relative;
    z-index: var(--layer-base);
  }

  .hero__media-wrapper--mobile {
    display: none;
  }

  .hero__media-wrapper--desktop {
    display: block;
  }

  @media screen and (max-width: 749px) {
    .hero__media-wrapper--desktop {
      display: none;
    }

    .hero__media-wrapper--mobile {
      display: block;
    }

    .hero__media-grid {
      grid-template-columns: repeat(var(--hero-media-count-mobile, 1), 1fr);
    }

    .hero--stack-mobile .hero__media-grid {
      grid-template-columns: 1fr;
      grid-template-rows: repeat(var(--hero-media-count-mobile, 1), calc(100% / var(--hero-media-count-mobile, 1)));
    }
  }

  .hero__link {
    position: absolute;
    inset: 0;
    grid-column: 1 / -1;
  }

  .hero__media-grid,
  .hero__content-wrapper {
    pointer-events: none;

    :is(a, button, input, textarea, select, details, summary) {
      pointer-events: auto;
    }
  }

  .hero__content-wrapper--design-mode * {
    pointer-events: auto;
  }

  .hero__heading,
  .hero__text,
  .hero__buttons {
    color: inherit;
  }

  .hero__buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .layout-panel-flex {
    display: flex;
    flex-direction: var(--flex-direction, column);
    flex-wrap: var(--flex-wrap-mobile, wrap);
    gap: var(--gap, 1rem);
    align-items: var(--vertical-alignment-mobile, center);
    justify-content: var(--horizontal-alignment, flex-start);

    @media screen and (min-width: 750px) {
      flex-wrap: var(--flex-wrap, nowrap);
      align-items: var(--vertical-alignment, center);
    }
  }

  .layout-panel-flex.mobile-column {
    @media screen and (max-width: 749px) {
      flex-direction: column;
    }
  }

  .hero[data-blur-shadow='true'] {
    --blurred-reflection-filter-saturate: saturate(1.5);
    --blurred-reflection-mask-image: linear-gradient(to bottom, #000 0%, #000 60%, transparent 100%);
    --blurred-reflection-box-shadow: rgb(0 0 0 / 5%) 0 0 1rem;
    --blurred-reflection-filter-blur: blur(20px);
    --blurred-reflection-scale: scale(2, 1.25);
    --blurred-reflection-padding-block-end: 60px;
  }

  .hero[data-blur-shadow='true'] .hero__container::before {
    content: '';
    position: absolute;
    inset: 0;
    box-shadow: var(--blurred-reflection-box-shadow);
    mix-blend-mode: overlay;
    pointer-events: none;
    z-index: -1;
  }

  .hero__blurred-image {
    position: absolute;
    inset: 0;
    z-index: -1;
    mask-image: var(--blurred-reflection-mask-image);
    filter: var(--blurred-reflection-filter-saturate);
    pointer-events: none;
    transform: translateY(50%);
    overflow: hidden;
  }

  .hero__blurred-image--desktop {
    display: none;

    @media screen and (min-width: 750px) {
      display: block;
    }
  }

  .hero__blurred-image--mobile {
    display: block;

    @media screen and (min-width: 750px) {
      display: none;
    }
  }

  .hero__blurred-image img,
  .hero__blurred-image svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center center;
    filter: var(--blurred-reflection-filter-blur);
    opacity: var(--blur-opacity);
    transform: var(--blurred-reflection-scale);
    padding-block-end: var(--blurred-reflection-padding-block-end);

    &:not(:only-child) {
      width: calc(100% / var(--hero-media-count, 1));

      &:last-child {
        right: 0;
        left: auto;
      }
    }
  }

  .spacing-style {
    padding-block-start: var(--padding-block-start, 0);
    padding-block-end: var(--padding-block-end, 0);
    padding-inline-start: var(--padding-inline-start, 0);
    padding-inline-end: var(--padding-inline-end, 0);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Hero",
  "tag": "section",
  "class": "hero-wrapper section-wrapper",
  "disabled_on": {
    "groups": ["header"]
  },
  "blocks": [
    {
      "type": "heading",
      "name": "Heading",
      "limit": 1,
      "settings": [
        {
          "type": "inline_richtext",
          "id": "heading",
          "default": "Hero heading",
          "label": "Heading"
        },
        {
          "type": "select",
          "id": "heading_size",
          "label": "Heading size",
          "options": [
            { "value": "h2", "label": "Small" },
            { "value": "h1", "label": "Medium" },
            { "value": "h0", "label": "Large" },
