<style>
.mpn-switcher {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
}
.mpn-switcher-item img {
  display: block;
  border: 2px solid transparent;
}
.mpn-switcher-item img.is-active {
  border-color: black;
}
</style>

{% assign current_mpn = product.metafields['shopify--facts']['mpn'].value %}

<p style="background:#ff0;padding:8px;font-size:12px;">
  <strong>DEBUG — current MPN:</strong> {{ current_mpn | default: '(blank)' }}<br>
  {% for collection in product.collections %}
    <strong>Collection:</strong> {{ collection.title }} ({{ collection.products | size }} products shown in Liquid)<br>
    {% for p in collection.products %}
      &nbsp;&nbsp;{{ p.title }} — MPN: {{ p.metafields['shopify--facts']['mpn'].value | default: '(none)' }}<br>
    {% endfor %}
  {% endfor %}
</p>

{% if current_mpn != blank %}
  {% assign shown_ids = "" %}
  <div class="mpn-switcher">
    {% for collection in product.collections %}
      {% for p in collection.products %}
        {% assign p_mpn = p.metafields['shopify--facts']['mpn'].value %}
        {% if p_mpn == current_mpn %}
          {% assign p_id_str = p.id | append: "" %}
          {% unless shown_ids contains p_id_str %}
            {% assign shown_ids = shown_ids | append: p_id_str | append: "," %}
            <a href="{{ p.url }}" class="mpn-switcher-item">
              <img
                src="{{ p.featured_image | image_url: width: 50 }}"
                alt="{{ p.title }}"
                loading="lazy"
                class="mpn-related-item {% if p.id == product.id %}is-active{% endif %}"
              >
            </a>
          {% endunless %}
        {% endif %}
      {% endfor %}
    {% endfor %}
  </div>
{% endif %}
